{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Remote Control Host",
  "version": "0.1.8",
  "identifier": "dev.laysath.remote-control-for-windows.host-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Remote Control Host",
        "width": 980,
        "height": 720,
        "minWidth": 360,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false
  }
}
